[{"id": 31, "subject": "sira", "course_number": 20, "chapter_index": 5, "title": "هبة السيدة سودة لنوبتها", "content": "وَوَهَبَتْ نَوْبَتَهَا لِعَائِشَهْ سَوْدَةُ مَا دَامَتْ زَمَانًا عَائِشَهْ. وهذا سبق لنا الإشارة إليه لما تحدثنا عن زواج النبي صلى الله عليه وسلم بالسيدة <b>سودة</b>، فلما خشيت السيدة سودة بنت زمعة خشيت أن يطلقها النبي عليه الصلاة والسلام لكبر سنها، وخشيت أن يبقى عندها ذلك المقام وهو مقام أم المؤمنين، قالت له: يا رسول الله أهب نوبتي للسيدة <b>عائشة</b>، ولا عليك من أن تبيت عندي في ليلتي، اجعل ليلتي لعائشة. فتكون لك لكل زوجة ليلة، ويكون للسيدة عائشة ليلتان، لعلمها رضي الله عنها بحب النبي صلى الله عليه وسلم للسيدة عائشة.", "youtube_link": "https://www.youtube.com/watch?v=WtFKmOg2T2Y&t=1427", "timestamp_seconds": 1427, "vocabulary_spoilers": "سودة بنت زمعة - عائشة - النوبة - زوجات النبي", "poetry_verses": null}, {"id": 36, "subject": "nahw", "course_number": 16, "chapter_index": 5, "title": "تعريف المبتدأ وعوامله", "content": "باب المبتدأ والخبر، وفيه نوعان من المرفوعات: المبتدأ والخبر كلاهما. يبدأ بالمبتدأ، يقول: <b>المبتدأ هو الاسم المرفوع العاري عن العوامل اللفظية</b>. المبتدأ إذا أردت الاختصار تقول: المبتدأ هو الاسم المرفوع الذي يبدأ به الكلام، لكن هذا بطبيعة الحال ليس ليس تعريفاً صحيحاً، لكن إذا أردنا الاختصار هو كذلك؛ فهو اسم مرفوع عارٍ أي مجرد عن العوامل اللفظية. فمثلاً حين أقول: كَانَ زَيْدٌ قَائِماً، زيدٌ صحيح أنه اسم مرفوع لكن فيه عامل لفظي يعمل فيه وهو \"كَانَ\". قَامَ زَيْدٌ، زيدٌ فاعل للفعل قام فـ \"قَامَ\" هو الفاعل الذي يعمل فيه، فإذاً هذه الأسماء ليست مجردة عن العوامل اللفظية؛ الأسماء المرفوعة تجد لها عوامل تعمل فيها عوامل لفظية، يعني مُتلفظاً بها. لكن المبتدأ حين تقول: زَيْدٌ قَائِمٌ، زيدٌ هذا مبتدأ مرفوع، ما الذي رفعه؟ أين العامل اللفظي الذي عمل فيه؟ يقولون: لا يوجد عامل لفظي عامل فيه، ولكن يوجد عامل معنوي؛ ما هذا العامل المعنوي؟ قالوا: هو <b>الابتداء</b>، مبتدأ مرفوع بالابتداء.", "youtube_link": null, "timestamp_seconds": 1132, "vocabulary_spoilers": "المبتدأ - الابتداء - عامل معنوي - عوامل لفظية", "poetry_verses": null}, {"id": 37, "subject": "nahw", "course_number": 16, "chapter_index": 6, "title": "المبتدأ الذي له فاعل سد مسد الخبر", "content": "والثاني، هذا هو الذي نحتاج إلى أن نقف عنده: مبتدأ له مرفوع سد مسد الخبر، ما معنى ذلك؟ معنى أنه قد يقع المبتدأ، قد يكون المبتدأ اسم فاعل أو اسم مفعول، ونحن قد ذكرنا من قبل أن اسم الفاعل واسم المفعول يعملان عمل الفعل، بمعنى يكون لهما مرفوع؛ اسم الفاعل يرفع مرفوعاً كما أن الفعل يرفع مرفوعاً هو فاعله، جميل. إذن الثاني يقول: هو اسم الفاعل واسم المفعول إذا تقدم عليهما نفي أو استفهام؛ نحو: <b>أَقَائِمٌ الزَّيْدَانِ؟</b> همزة الاستفهام إذاً الاستفهام موجود، قائمٌ: مبتدأ وأنت ترى أنه على صيغة اسم الفاعل، الزيدان: فاعل لِاسم الفاعل \"قائم\" سد مسد الخبر؛ بمعنى أن هذا المبتدأ، هذا المبتدأ حين رفع فاعلاً لم يحتج بعد ذلك إلى خبر، فإن ذلك الفاعل يقوم مقام الخبر أو يسد مسد الخبر. وكذلك: <b>مَا قَائِمٌ الزَّيْدَانِ</b>؛ هنا حالة الاعتماد على النفي لا الاستفهام، ما: نافية، قائمٌ: مبتدأ، الزيدان: فاعل لِاسم الفاعل لأن اسم الفاعل وهو قائمٌ يعمل عمل الفعل. وكذلك: <b>هَلْ مَضْرُوبٌ الْعُمْرَانِ؟</b> هل: أداة استفهام حرف استفهام، مضروبٌ: مبتدأ وهو على صيغة اسم المفعول، العِمران هذا نائب فاعل لِمضروب، واضح؛ نائب فاعل سد مسد الخبر.", "youtube_link": null, "timestamp_seconds": 1309, "vocabulary_spoilers": "اسم الفاعل - اسم المفعول - سد مسد الخبر - استفهام", "poetry_verses": null}, {"id": 38, "subject": "nahw", "course_number": 16, "chapter_index": 7, "title": "مسوغات الابتداء بالنكرة", "content": "ولا يكون المبتدأ نكرة إلا بمسوغ، والمسوغات كثيرة؛ منها أن يتقدم على النكرة نفي أو استفهام، ومنها أن تكون موصوفة، إلى غير ذلك؛ هذه هي مسوغات الابتداء بالنكرة. فالاصل أن المبتدأ لا يكون نكرة وإنما يكون معرفة، ولا يجوز الابتداء بنكرة ما لم تفد. قال: منها أن يتقدم على النكرة نفي أو استفهام، نحو: مَا رَجُلٌ قَائِماً، وَهَلْ رَجُلٌ جَالِسٌ. ومنها من المسوغات: أن تكون موصوفة، نحو: {وَلَعَبْدٌ مُّؤْمِنٌ خَيْرٌ}؛ أن تكون موصوفة أن يكون المبتدأ متبوعاً بنعت بصفة، نحو: وَلَعَبْدٌ مُّؤْمِنٌ، عبدٌ: مبتدأ هو نكرة، ما الذي سوغ الابتداء بالنكرة؟ وجود النعت \"مؤمن\". ومنها: أن تكون مضافة، نحو حديث: \"خَمْسُ صَلَوَاتٍ كَتَبَهُنَّ اللَّهُ\"؛ خمسُ: مبتدأ وهو نكرة مضاف، صلواتٍ: مضاف إليه مجرور، مسوغ الابتداء بالنكرة وجود هذه الإضافة. ومنها أي من المسوغات: أن يكون الخبر ظرفاً أو جاراً ومجروراً مقدمين على النكرة، يعني تبدأ بالظرف أو بالجار والمجرور؛ نحو: عِنْدَكَ رَجُلٌ، فِي الدَّارِ امْرَأَةٌ؛ امرأةٌ: مبتدأ مؤخر وهو نكرة، ما الذي سوغ ذلك؟ تقدم الجار والمجرور.", "youtube_link": null, "timestamp_seconds": 1632, "vocabulary_spoilers": "المسوغات - الابتداء بالنكرة - موصوفة - مضافة", "poetry_verses": null}, {"id": 42, "subject": "aqeeda", "course_number": 20, "chapter_index": 4, "title": "دخول الشرك إلى الجزيرة العربية", "content": "ثم نأتي إلى الجزيرة العربية؛ أول من أدخل الشرك إلى الجزيرة العربية هو <b>عمرو بن لحي الخزاعي</b>، وهذا الرجل كان عُرف بفعل الخير وبالصدقة والحرص على أمور الدين والعبادات. (...) سافر إلى الشام فرأىهم يعبدون الأوثان فاستحسن هذا الأمر؛ ولما عاد إلى مكة جاء بصنم وهو \"هبل\" المعروف، فجعله في جوف الكعبة ودعا أهل مكة إلى عبادته فأطاعوه. (...) ثم كثر الشرك في الجزيرة العربية، ونصبت الأوثان في كل بقعة من هذه الجزيرة، بل في كل بيت حتى صار في كل بيت صنم بل أصنام في كل البيوت. (...) النبي عليه الصلاة والسلام شهد لهذا الرجل بالنار؛ رواه الشيخان عن أبي هريرة رضي الله عنه أن رسول الله صلى الله عليه وسلم قال: \"رأيت عمرو بن لحي يجر قصبه في النار\".", "youtube_link": null, "timestamp_seconds": 922, "vocabulary_spoilers": "عمرو بن لحي الخزاعي - هبل - مكة - الشام - نار جهنم", "poetry_verses": null}, {"id": 43, "subject": "aqeeda", "course_number": 20, "chapter_index": 5, "title": "أسباب الشرك وأرضيته", "content": "بعض العلماء قال بالنظر إلى أسباب كل هذا، قال إن الشرك له سببان رئيسان بالإضافة طبعاً إلى الأرضية هي الجهل؛ قال هو الغلو في المخلوق. (...) النبي عليه الصلاة والسلام نهى أن يبالغ المسلمون في تعظيمه، نعم هو رجل معظم هو سيد الخلق ولكنه بشر. (...) الأمر الثاني هو سوء الظن بالله؛ إذا اجتمع الغلو في المخلوق مع سوء الظن بالله في أرضية انتشر فيها الجهل، فإنها تفضي إلى ظهور الشرك.", "youtube_link": null, "timestamp_seconds": 1222, "vocabulary_spoilers": "الغلو - سوء الظن بالله - الجهل - سد الذرائع", "poetry_verses": null}, {"id": 48, "subject": "sira", "course_number": 21, "chapter_index": 5, "title": "حج أبي بكر وتلاوة سورة براءة", "content": "وحج بالناس أبو بكر وثم تلا براءة علي وحتم: ذهب المسلمون إلى مكة في موسم الحج ليحجوا، ولم يذهب معهم النبي صلى الله عليه وسلم وإنما أمّر عليهم أبا بكر الصديق.\n\nأرسل النبي صلى الله عليه وسلم علياً رضي الله عنه وقال لهم: تذهبون مدداً لأبي بكر ولستم أمراء، يعني تذهبون تحت إمرته ولكن تتلون على الناس ما جاء في مطلع سورة براءة: {بَرَاءَةٌ مِّنَ اللَّهِ وَرَسُولِهِ إِلَى الَّذِينَ عَاهَدتُّم مِّنَ الْمُشْرِكِينَ}.\n\nألا يحج بعد اليوم مشرك، ولا يطوف بالبيت عريان، وأنه لا تدخل الجنة إلا نسمة مؤمنة.", "youtube_link": "https://www.youtube.com/watch?v=wTKR0lNTGiE&t=694", "timestamp_seconds": 694, "vocabulary_spoilers": "أبو بكر الصديق - سورة براءة - الحج الأكبر", "poetry_verses": null}, {"id": 49, "subject": "sira", "course_number": 21, "chapter_index": 6, "title": "عام الوفود وإيلاء النبي صلى الله عليه وسلم", "content": "وجاءت الوفود فيها تترى: أي في السنة التاسعة وجاءت الوفود فيها تترى. والسنة التاسعة في كتب السير والمغازي كانت تسمى بعام الوفود. عام الوفود هو العام الذي يفد فيه الناس أفواجاً على النبي صلى الله عليه وسلم يعلنون مبايعتهم وإسلامهم.\n\nهذا ومن نسائه آلى شهراً: آلى من نسائه لأنه كان وقع بعض الشنآن، فاعتزل صلى الله عليه وسلم نساءه تسعة وعشرين يوماً ثم بعد ذلك عاد إلى نسائه عليه الصلاة والسلام، واعتزلهم في مشربة له وكان لا يدخل عليه إلا القليل من أصحابه.", "youtube_link": "https://www.youtube.com/watch?v=wTKR0lNTGiE&t=1048", "timestamp_seconds": 1048, "vocabulary_spoilers": "عام الوفود - الإيلاء - مشربة", "poetry_verses": null}, {"id": 50, "subject": "sira", "course_number": 21, "chapter_index": 7, "title": "وفاة النجاشي وصلاة الغائب", "content": "ثم النجاشي نعى وصلى عليه من طيبة نال الفضلا: يخرج النبي صلى الله عليه وسلم على أصحابه فيقول لهم إن الله عز وجل قد أوحى إليه بخبر وفاة النجاشي، هذا الرجل الصالح المسلم.\n\nأخبرهم بأن يخرجوا معه إلى خارج المدينة فصلى عليه صلاة الغائب، ونال النجاشي هذا الفضل أن النبي صلى الله عليه وسلم جعل له هذا الاعتبار العالي، وفي نفس الوقت أن النبي صلى الله عليه وسلم صلى عليه من المدينة المنورة.", "youtube_link": "https://www.youtube.com/watch?v=wTKR0lNTGiE&t=1219", "timestamp_seconds": 1219, "vocabulary_spoilers": "النجاشي - صلاة الغائب - طيبة", "poetry_verses": null}, {"id": 51, "subject": "sira", "course_number": 21, "chapter_index": 8, "title": "وفاة إبراهيم وكسوف الشمس", "content": "ومات إبراهيم في العام الأخير والبجلي أسلم واسمه جرير: إبراهيم ابن النبي صلى الله عليه وسلم من السيدة مارية، ولدته له في السنة الثامنة، وتوفاه الله عز وجل في السنة العاشرة.\n\nصادف من قدر الله مع وفاة إبراهيم أن وقع كسوف للشمس، فجعل الناس يقولون: لقد خسفت الشمس لموت ابن رسول الله صلى الله عليه وسلم، وهذا أمر عقدي خطير.\n\nخرج إليهم وقال: يا أيها الناس إنما الشمس والقمر مخلوقان من مخلوقات الله، لا ينكسفان ولا ينخسفان لحياة أحد ولا لموته. وأمر الناس بأن يهرعوا إلى الصلاة، فسنّ لهم صلى الله عليه وسلم صلاة الكسوف.", "youtube_link": "https://www.youtube.com/watch?v=wTKR0lNTGiE&t=1360", "timestamp_seconds": 1360, "vocabulary_spoilers": "إبراهيم - مارية القبطية - كسوف الشمس", "poetry_verses": null}, {"id": 64, "subject": "aqeeda", "course_number": 15, "chapter_index": 4, "title": "ظهور الفطرة في أوقات الشدائد", "content": "في أوقات الشدة والمصائب حين تنقطع الحيل والأسباب، ماذا يفعل الإنسان؟ يتوجه إلى الله خالقه ويرجوه ويلتجئ إليه بإخلاص. قال تعالى: {حَتَّىٰ إِذَا كُنتُمْ فِي الْفُلْكِ وَجَرَيْنَ بِهِم بِرِيحٍ طَيِّبَةٍ وَفَرِحُوا بِهَا جَاءَتْهَا رِيحٌ عَاصِفٌ وَجَاءَهُمُ الْمَوْجُ مِن كُلِّ مَكَانٍ وَظَنُّوا أَنَّهُمْ أُحِيطَ بِهِمْ ۙ دَعَوُا اللَّهَ مُخْلِصِينَ لَهُ الدِّينَ}.\n\nقال الإمام <b>الشوكاني</b> رحمه الله تعالى في تفسير هذه الآية: \"في هذا دليل على أن الخلق جُبلوا على الرجوع إلى الله في الشدائد، وأن هؤلاء المشركين كانوا لا يلتفتون إلى أصنامهم في هذه الحالة\".", "youtube_link": "https://www.youtube.com/watch?v=25qW6_Q653Y&t=272", "timestamp_seconds": 272, "vocabulary_spoilers": "الشدائد - الإمام الشوكاني - الفطرة - الإخلاص", "poetry_verses": null}, {"id": 65, "subject": "aqeeda", "course_number": 15, "chapter_index": 5, "title": "قصة عكرمة بن أبي جهل كنموذج", "content": "تُروى قصة عن <b>عكرمة بن أبي جهل</b>؛ فقد هرب من <b>مكة</b> وركب البحر فأصابهم عاصف، فقال أصحاب السفينة لأهلها: \"أخلصوا؛ فإن آلهتكم لا تغني عنكم شيئاً\".\n\nفقال <b>عكرمة</b>: \"لئن لم ينجِ في البحر إلا الإخلاص، ما ينجيني في البر غيره\". ثم عاهد الله إن عافاه أن يأتي <b>محمداً</b> ﷺ، فأنجاه الله وأسلم وحسن إسلامه. فالإنسان يرجع إلى فطرته في الشدائد وتستيقظ فطرته ويخاطب خالقه.", "youtube_link": "https://www.youtube.com/watch?v=25qW6_Q653Y&t=466", "timestamp_seconds": 466, "vocabulary_spoilers": "عكرمة بن أبي جهل - مكة - الإخلاص", "poetry_verses": null}, {"id": 66, "subject": "aqeeda", "course_number": 15, "chapter_index": 6, "title": "دليل العقل على جمال التوحيد وقبح الشرك", "content": "الدليل الثاني هو <b>العقل</b>، وذلك ببيان جمال <b>التوحيد</b> وحسن <b>التوحيد</b> وبيان سوء <b>الشرك</b> وقبح <b>الشرك</b>. فمن الذي خلقك؟ الله. مَن الذي رزقك؟ الله. فكيف يأتي هذا الإنسان الذي أخذ كل شيء من الله، فيسأل غير الله؟\n\nلذلك قال <b>إبراهيم</b> عليه السلام: {أَتَعْبُدُونَ مَا تَنْحِتُونَ * وَاللَّهُ خَلَقَكُمْ وَمَا تَعْمَلُونَ}. فهذا في غاية القبح؛ أن تعبد ما صنعت بيدك وتترك الخالق الرازق.", "youtube_link": "https://www.youtube.com/watch?v=25qW6_Q653Y&t=568", "timestamp_seconds": 568, "vocabulary_spoilers": "العقل - التوحيد - الشرك - إبراهيم عليه السلام", "poetry_verses": null}, {"id": 67, "subject": "aqeeda", "course_number": 15, "chapter_index": 7, "title": "غياب الحجة لدى المشركين", "content": "من الاستدلال العقلي أيضاً: غياب الحجة عند المشركين. قال تعالى: {وَمَا يَتَّبِعُ الَّذِينَ يَدْعُونَ مِن دُونِ اللَّهِ شُرَكَاءَ ۚ إِن يَتَّبِعُونَ إِلَّا الظَّنَّ وَإِنْ هُمْ إِلَّا يَخْرُصُونَ}.\n\nقال الحافظ <b>ابن كثير</b> رحمه الله تعالى: \"أخبر تعالى أن المشركين يعبدون الأصنام وهي لا تملك شيئاً ولا ضراً ولا نفعاً، ولا دليل لهم على عبادتهم\". وقال تعالى حاكياً عن أصحاب الكهف: {لَوْلَا يَأْتُونَ عَلَيْهِم بِسُلْطَانٍ بَيِّنٍ}. وقطعاً لا حجة لديهم.", "youtube_link": "https://www.youtube.com/watch?v=25qW6_Q653Y&t=684", "timestamp_seconds": 684, "vocabulary_spoilers": "ابن كثير - سلطان مبين - الظن - المشركون", "poetry_verses": null}, {"id": 68, "subject": "aqeeda", "course_number": 15, "chapter_index": 8, "title": "ضرب الأمثال في القرآن", "content": "من الأدلة العقلية أيضاً: ضرب الأمثال لما كان يفعله المشركون؛ مثلاً في سورة <b>الزمر</b> يقول الله تعالى: {ضَرَبَ اللَّهُ مَثَلًا رَّجُلًا فِيهِ شُرَكَاءُ مُتَشَاكِسُونَ وَرَجُلًا سَلَمًا لِّرَجُلٍ}.\n\nهذا مثل للمشرك الذي يعبد آلهة شتى والموحد الذي يعبد إلهاً واحداً. الأول كأنه عبد له عدة أسياد متنازعين فيلقى العناء، بخلاف الذي يخدم رجلاً واحداً، فهذا يكون قرير العين مرتاح النفس. وهذا مسلك قرآني مهم في الدعوة.", "youtube_link": "https://www.youtube.com/watch?v=25qW6_Q653Y&t=785", "timestamp_seconds": 785, "vocabulary_spoilers": "سورة الزمر - ضرب الأمثال - شركاء متشاكسون", "poetry_verses": null}, {"id": 69, "subject": "aqeeda", "course_number": 15, "chapter_index": 9, "title": "استلزام الربوبية للألوهية", "content": "كذلك من أدلة الألوهية: <b>ربوبية</b> الله تعالى نفسها. إذا سألك سائل: مَن خلقك؟ تقول: الله. مَن رزقك؟ الله. إذاً أنت موحد توحيد <b>الربوبية</b>. فتوحيد <b>الربوبية</b> دليل على توحيد <b>الألوهية</b>.\n\nلأن الخالق المالك المدبر الذي تفرد بالنعم الظاهرة والباطنة هو الذي يستحق أن يُعبد دون ما سواه، وهو ما يُسمى استلزام <b>الربوبية</b> للألوهية.", "youtube_link": "https://www.youtube.com/watch?v=25qW6_Q653Y&t=916", "timestamp_seconds": 916, "vocabulary_spoilers": "الربوبية - الألوهية - استلزام الربوبية للألوهية", "poetry_verses": null}, {"id": 70, "subject": "aqeeda", "course_number": 15, "chapter_index": 10, "title": "الأدلة النقلية من القرآن", "content": "ننتقل إلى الأدلة النقلية؛ ما هي الآيات والأحاديث التي تتحدث عن توحيد الألوهية؟ فمثلاً في سورة <b>الفاتحة</b> التي يحفظها كل المسلمين: {إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ}. \n\nتقديم المعمول هنا يفيد الحصر، أي لا نعبد إلا إياك. كذلك قوله تعالى: {شَهِدَ اللَّهُ أَنَّهُ لَا إِلَٰهَ إِلَّا هُوَ}، و{فَاعْلَمْ أَنَّهُ لَا إِلَٰهَ إِلَّا اللَّهُ}. آيات كثيرة جداً، والقرآن الكريم نزل من أجل هذا الأمر.", "youtube_link": "https://www.youtube.com/watch?v=25qW6_Q653Y&t=974", "timestamp_seconds": 974, "vocabulary_spoilers": "سورة الفاتحة - الأدلة النقلية - الحصر", "poetry_verses": null}, {"id": 71, "subject": "aqeeda", "course_number": 15, "chapter_index": 11, "title": "اتفاق الأنبياء على توحيد الألوهية", "content": "زبدة دعوة الأنبياء والرسل هو الدعوة إلى عبادة الله وحده. وقد تضافرت الأدلة على أن كل الأنبياء والرسل إنما بُعثوا لبيان ألوهية الله تعالى وحده.\n\nقال تعالى: {وَمَا أَرْسَلْنَا مِن قَبْلِكَ مِن رَّسُولٍ إِلَّا نُوحِي إِلَيْهِ أَنَّهُ لَا إِلَٰهَ إِلَّا أَنَا فَاعْبُدُونِ}. فاتفاق الرسل على هذا المبدأ دليل على أهمية عبادة الله وحده بل على ركنية هذه القضية، قضية ركن من أركان الوجود.", "youtube_link": "https://www.youtube.com/watch?v=25qW6_Q653Y&t=1272", "timestamp_seconds": 1272, "vocabulary_spoilers": "الأنبياء - الرسل - الدعوة إلى التوحيد", "poetry_verses": null}, {"id": 72, "subject": "aqeeda", "course_number": 14, "chapter_index": 1, "title": "التلازم والارتباط بين توحيد الربوبية وتوحيد الألوهية", "content": "بيّن الشيخ التلازم العقلي والشرعي بين توحيد الربوبية وتوحيد الألوهية، موضحاً أن الإقرار بالربوبية يستلزم إفراد الله بالعبادة، وأن الخلل في الألوهية ناشئ عن خلل في الربوبية.", "youtube_link": "https://www.youtube.com/watch?v=uPUV_0ecAKw&t=46s", "timestamp_seconds": 46, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 73, "subject": "aqeeda", "course_number": 14, "chapter_index": 2, "title": "توحيد الألوهية غاية الخلق والاستدلال بالقرآن عليه", "content": "أوضح الشيخ أن توحيد الألوهية هو الغاية العظمى من خلق الجن والإنس، مستعرضاً الأدلة القرآنية التي تستدل بتوحيد الربوبية وتفرده بالخلق والملك على وجوب إفراده بالعبادة وحده.", "youtube_link": "https://www.youtube.com/watch?v=uPUV_0ecAKw&t=467s", "timestamp_seconds": 467, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 74, "subject": "aqeeda", "course_number": 14, "chapter_index": 3, "title": "دعوة الأنبياء والرسل لتوحيد الألوهية وحق الله على العباد", "content": "بيّن الشيخ أن جميع الأنبياء والرسل بعثوا بدعوة واحدة وهي عبادة الله وحده واجتناب الشرك، وأن هذا التوحيد هو زبدة الأديان وحق الله الواجب على جميع العباد.", "youtube_link": "https://www.youtube.com/watch?v=uPUV_0ecAKw&t=838s", "timestamp_seconds": 838, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 75, "subject": "aqeeda", "course_number": 15, "chapter_index": 1, "title": "الاستدلال على توحيد الألوهية بدليل الفطرة", "content": "تناول الشيخ دليل الفطرة على توحيد الألوهية، مبيناً أن الإنسان مجبول على العبادة بطبعه، وأن هذه الفطرة تظهر بجلاء وتستيقظ في نفوس البشر عند وقوع الشدائد والمصائب وانقطاع الأسباب.", "youtube_link": "https://www.youtube.com/watch?v=25qW6_Q653Y&t=51s", "timestamp_seconds": 51, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 76, "subject": "aqeeda", "course_number": 15, "chapter_index": 2, "title": "الاستدلال العقلي على توحيد الألوهية وبطلان الشرك", "content": "استعرض الشيخ براهين العقل على التوحيد، كبيان جمالية التوحيد وقبح الشرك، وإفلاس المشركين من الحجة، وضرب الأمثال القرآنية لتقريب المعاني الإيمانية، مبيناً كيف يستلزم توحيد الربوبية الإقرار بتوحيد الألوهية.", "youtube_link": "https://www.youtube.com/watch?v=25qW6_Q653Y&t=568s", "timestamp_seconds": 568, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 77, "subject": "aqeeda", "course_number": 15, "chapter_index": 3, "title": "الأدلة النقلية من الوحي ودعوة الرسل لتوحيد الألوهية", "content": "فصّل الشيخ الأدلة النقلية من القرآن والسنة، مبيناً دلالة سورة الفاتحة والآيات والأحاديث النبوية المتضافرة، ومؤكداً على اتفاق جميع الرسل على مبدأ عبادة الله وحده واجتناب الطاغوت.", "youtube_link": "https://www.youtube.com/watch?v=25qW6_Q653Y&t=974s", "timestamp_seconds": 974, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 78, "subject": "aqeeda", "course_number": 16, "chapter_index": 1, "title": "الفروق اللغوية والمفهومية بين توحيد الربوبية والألوهية", "content": "أوضح الشيخ الفروق التأسيسية بين توحيد الربوبية والألوهية من حيث الاشتقاق اللغوي، والتعلق بالأمور الكونية مقابل الشرعية، وتقسيم الأفعال بين أفعال الله سبحانه وأفعال العباد.", "youtube_link": "https://www.youtube.com/watch?v=b9tE0RFZ_zg&t=67s", "timestamp_seconds": 67, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 79, "subject": "aqeeda", "course_number": 16, "chapter_index": 2, "title": "الفروق من حيث إقرار الخلق والمدار والوسيلة والمقصود", "content": "استعرض المحاضر الفروق بين التوحيدين من جهة إقرار المشركين بالربوبية دون الألوهية، وكون مدار الربوبية علمياً ووسيلته القلب واللسان، بينما مدار الألوهية عملياً ووسائله تشمل الجوارح أيضاً.", "youtube_link": "https://www.youtube.com/watch?v=b9tE0RFZ_zg&t=288s", "timestamp_seconds": 288, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 80, "subject": "aqeeda", "course_number": 16, "chapter_index": 3, "title": "الأحكام الشرعية المترتبة وتلازم الربوبية والألوهية", "content": "بيّن الشيخ الأحكام المترتبة على التوحيدين كالحكم بالإسلام والنفع في الآخرة، ومحور دعوة الرسل، والغاية من الخلق، مؤكداً على التلازم الوثيق بينهما واستحالة فصل أحدهما عن الآخر اعتقاداً.", "youtube_link": "https://www.youtube.com/watch?v=b9tE0RFZ_zg&t=500s", "timestamp_seconds": 500, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 81, "subject": "aqeeda", "course_number": 17, "chapter_index": 1, "title": "مقدمة الدرس ونشأة الكلام في توحيد الأسماء والصفات", "content": "يتناول الشيخ تمهيداً للدرس يستعرض فيه تاريخ نشأة الكلام في توحيد الأسماء والصفات، موضحاً سبب تأخر التدوين والتصنيف فيه لعدم وجود الحاجة إليه في صدر الإسلام حتى ظهرت الفرق الضالة وتُرجمت كتب الفلاسفة.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 82, "subject": "aqeeda", "course_number": 17, "chapter_index": 2, "title": "تعريف الأسماء والصفات لغة واصطلاحاً وأدلتهما", "content": "يبيّن الشيخ المعاني اللغوية والاصطلاحية لكل من الأسماء والصفات، مؤكداً على أن مصدرها هو الوحي من الكتاب والسنة الصحيحة، مع تقسيم الصفات إلى ذاتية وفعلية ومعنوية والتمثيل لها.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 83, "subject": "aqeeda", "course_number": 17, "chapter_index": 3, "title": "حقيقة توحيد الأسماء والصفات والمنهج الصحيح في إثباتها", "content": "يشرح الشيخ حقيقة هذا التوحيد القائم على الإثبات دون تعطيل أو تمثيل، ويوضح قاعدة أهل السنة في إمرار نصوص الصفات كما جاءت والإيمان بمقتضاها والتعبد بها دون الخوض في كيفياتها.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 84, "subject": "aqeeda", "course_number": 17, "chapter_index": 4, "title": "خلاصة مجمل اعتقاد أهل السنة والجماعة في الأسماء والصفات", "content": "يلخص الشيخ المنهج الإجمالي لأهل السنة القائم على إثبات ما أثبته الله ورسوله، ونفي ما نفياه، والسكوت عما سُكت عنه، مع تبيين الفروق الجوهرية بين أقسام التوحيد وما يتميز به كل قسم عن غيره.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 85, "subject": "aqeeda", "course_number": 18, "chapter_index": 1, "title": "أهمية توحيد الأسماء والصفات وسبيل معرفة الله", "content": "يوضح الشيخ أهمية معرفة الله من خلال أسمائه وصفاته، مبيناً حاجة الأرواح والعباد إلى هذه المعرفة، والسبل الموصلة إليها عن طريق الآيات الكونية والشرعية.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 86, "subject": "aqeeda", "course_number": 18, "chapter_index": 2, "title": "الفرق بين أسماء الله تعالى وصفاته", "content": "يشرح الشيخ الفارق الدقيق بين الاسم والصفة؛ فالاسم يدل على الذات والصفة معاً، بينما تدل الصفة على نعت الكمال فقط، مع بيان أن باب الصفات أوسع من باب الأسماء.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 87, "subject": "aqeeda", "course_number": 18, "chapter_index": 3, "title": "قاعدة التوقيف في أسماء الله وصفاته ومسألة الإخبار", "content": "يبين الشيخ أن أسماء الله وصفاته توقيفية لا يجوز الابتداع فيها، مفرقاً بين التسمية وباب الإخبار الأوسع، مع توضيح الموقف الشرعي مما لم يرد إثباته ولا نفيه.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 88, "subject": "aqeeda", "course_number": 19, "chapter_index": 1, "title": "القاعدة الأولى: إثبات الأسماء والصفات وتجنب المحاذير الأربعة", "content": "شرح مفصل للقاعدة الأولى في باب الأسماء والصفات، وتوضيح وجوب الإثبات لله تعالى مع الحذر من الوقوع في التحريف والتعطيل والتكييف والتمثيل.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 89, "subject": "aqeeda", "course_number": 19, "chapter_index": 2, "title": "القاعدتان الثانية والثالثة: الكمال المطلق وأسلوب النفي والإثبات", "content": "عرض لقاعدتين جليلتين؛ وجوب اعتقاد الكمال المطلق في صفات الله سبحانه، واتباع طريقة القرآن في تفصيل الإثبات وإجمال النفي بخلاف مسلك المبتدعة.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 90, "subject": "aqeeda", "course_number": 19, "chapter_index": 3, "title": "تنبيهات منهجية في تلقي الأسماء والصفات وثمرتها السلوكية", "content": "أربعة تنبيهات هامة حول وجوب إمرار النصوص على ظاهرها، وتفويض الكيف لا المعنى، ومعرفة الله بما عرف به نفسه، والتركيز على الثمار السلوكية للإيمان بالصفات.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 91, "subject": "aqeeda", "course_number": 20, "chapter_index": 1, "title": "تعريف الشرك لغة واصطلاحاً وبيان فطرة التوحيد", "content": "عرّف الأستاذ الشرك في اللغة من مفهوم الشركة، وفي الاصطلاح العقدي بأنه صرف خصائص الإلهية لغير الله، مؤكداً أن الفطرة البشرية الأصلية مبنية على التوحيد.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 92, "subject": "aqeeda", "course_number": 20, "chapter_index": 2, "title": "بداية ظهور الشرك في البشرية وقصة قوم نوح", "content": "أوضح الشيخ كيف تسلل الشرك لأول مرة في تاريخ البشرية من خلال تعظيم تماثيل الرجال الصالحين في قوم نوح، مستدلاً بأثر ابن عباس في نسيان العلم كسبب رئيسي للشرك.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 93, "subject": "aqeeda", "course_number": 20, "chapter_index": 3, "title": "دخول الشرك إلى الجزيرة العربية والأسباب الرئيسية له", "content": "استعرض الشيخ قصة عمرو بن لحي الخزاعي الذي جلب الأصنام لمكة، ثم لخص أسباب الشرك في غياب العلم، والغلو في المخلوقين، وسوء الظن بالله سبحانه وتعالى.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 94, "subject": "aqeeda", "course_number": 21, "chapter_index": 1, "title": "إقرار مشركي العرب بربوبية الله والربط بين توحيد الربوبية والألوهية", "content": "بيّن الشيخ أن مشركي الجاهلية كانوا يقرّون بصفات الربوبية كالخلق والرزق إجمالاً، موضحاً المنهج الدعوي القائم على ربط توحيد الربوبية بالألوهية؛ إذ إن كل خلل في العبادة ينبع بالضرورة من خلل في اعتقاد الربوبية.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 95, "subject": "aqeeda", "course_number": 21, "chapter_index": 2, "title": "صور الشرك في الربوبية عند مشركي الجزيرة العربية", "content": "فصّل الشيخ في بعض المظاهر الشركية السائدة في الجاهلية والتي تمس توحيد الربوبية، كنسبة نزول المطر للأنواء والكواكب، وتعليق التمائم لطلب السلامة، وإتيان الكهان وتصديقهم في علم الغيب، والتطير بالطيور.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 96, "subject": "aqeeda", "course_number": 21, "chapter_index": 3, "title": "الشرك في الربوبية في التاريخ القديم والعصر الحديث", "content": "استعرض الشيخ نماذج تاريخية للشرك في الربوبية كادعاء النمروذ وفرعون وعقائد المجوس والدهرية، وربطها بالانحرافات المعاصرة كنسبة الخلق للطبيعة، ونظرية التطور، واعتقاد النفع والضر في الأضرحة والمشعوذين.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 97, "subject": "aqeeda", "course_number": 22, "chapter_index": 1, "title": "مفهوم الشرك في الألوهية وصورته الأولى: شرك العبادة والتعبد", "content": "يتناول هذا المحور تعريف الشرك في الألوهية مع التركيز على شرك العبادة الذي يمثل قصد غير الله بالشعائر التعبدية، مع التفريق بين الحكم على الفعل والفاعل.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 98, "subject": "aqeeda", "course_number": 22, "chapter_index": 2, "title": "شرك الدعاء والاستعانة والاستعاذة والاستغاثة", "content": "يشرح الشيخ شرك الدعاء وصور الاستعانة والاستعاذة والاستغاثة بغير الله عز وجل، ويوضح الضابط في التفريق بين الجائز منها والشركي.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 99, "subject": "aqeeda", "course_number": 22, "chapter_index": 3, "title": "شرك اتخاذ الوسائط والشفعاء", "content": "يتطرق هذا المحور لشرك اتخاذ الوسائط والشفعاء، وهو أن يجعل الإنسان وسيطاً بينه وبين الله ليوصل دعاءه وتقربه، مبيناً أنه من الشرك الأكبر.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 100, "subject": "aqeeda", "course_number": 23, "chapter_index": 1, "title": "صور الشرك في أعمال القلوب: الخوف والمحبة والرجاء", "content": "تناول الشيخ تفصيل الأقسام الثلاثة (الشرعي، والطبيعي المباح، والشركي) لعبادات الخوف والمحبة والرجاء، مبيناً أن الشرك فيها يقع عند صرف هذه المشاعر لغير الله مع التعظيم والخضوع.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 101, "subject": "aqeeda", "course_number": 23, "chapter_index": 2, "title": "عبادة التوكل وأقسامها والشرك فيها", "content": "شرح الشيخ عبادة التوكل كعمل قلبي يمثل نصف الدين، وفصل بين التوكل الشرعي على الله، والتوكل المباح بالاعتماد على الأسباب المقدرة مع كراهة اللفظ، والتوكل الشركي بالاعتماد على المخلوق فيما لا يقدر عليه إلا الله.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 102, "subject": "aqeeda", "course_number": 23, "chapter_index": 3, "title": "أعمال الجوارح وصور الشرك في الذبح", "content": "استعرض الشيخ حكم ذبح الأنعام مفرقاً بين الذبح المشروع كقربة لله (الأضاحي والهدي)، والذبح المباح (للأكل والتجارة)، والذبح الشركي الذي يُقصد به التقرب للأولياء والقبور لطلب الشفاء أو النفع.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 103, "subject": "fiqh", "course_number": 14, "chapter_index": 1, "title": "أركان الصلاة: السجود والاعتدال والسلام", "content": "شرح الشيخ فرائض السجود والاعتدال منه، مع التأكيد على ضرورة الطمأنينة، وبيان حكم السلام والجلوس له كأركان جوهرية في الصلاة.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 104, "subject": "fiqh", "course_number": 14, "chapter_index": 2, "title": "وجوب ترتيب فرائض الصلاة", "content": "أوضح الشيخ أن الترتيب بين أركان الصلاة فرض واجب، مستدلاً بحديث المسيء صلاته الذي استخدم فيه النبي (ﷺ) \"ثم\" الدالة على الترتيب والتعقيب.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 105, "subject": "fiqh", "course_number": 14, "chapter_index": 3, "title": "حكم الطمأنينة ومتابعة المأموم لإمامه", "content": "فصّل الشيخ في ركن الطمأنينة وذم العجلة في الصلاة، ثم انتقل لشرح وجوب متابعة المأموم لإمامه في الإحرام والسلام، محذراً من المسابقة التي تبطل الصلاة.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 106, "subject": "fiqh", "course_number": 14, "chapter_index": 4, "title": "نية الاقتداء وإمامة الصلاة", "content": "بيّن الشيخ وجوب نية الاقتداء للمأموم، وأوضح الحالات الأربع التي يجب فيها على الإمام استحضار نية الإمامة (الخوف، الجمع، الجمعة، والاستخلاف).", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 107, "subject": "fiqh", "course_number": 15, "chapter_index": 1, "title": "استقبال القبلة: توجيه القلب والبدن إلى المسجد الحرام", "content": "💡 التفسير التربوي: التوجه نحو القبلة هو رمز لوحدة المسلمين وتوجه قلوبهم نحو الخالق الواحد، وهو من مظاهر الانضباط في العبادة، حيث لا يترك للمصلي اختيار جهة الصلاة بل يلتزم بما حدده الشرع.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 108, "subject": "fiqh", "course_number": 15, "chapter_index": 2, "title": "طهارة الخبث: تجريد العبادة من كل دنس", "content": "💡 التفسير التربوي: الإسلام دين النظافة، وطهارة المحيط والمكان الذي نصلي فيه تعكس قدسية الصلاة وأثر الطهارة الظاهرة في إعداد النفس للطهارة الباطنية.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 109, "subject": "fiqh", "course_number": 15, "chapter_index": 3, "title": "ستر العورة: وقار المؤمن بين يدي ربه", "content": "💡 التفسير التربوي: الستر في الصلاة يعبر عن الحياء والوقار المطلوب من المؤمن في مقام المناجاة، وهو تذكير بأن الجسد أمانة ينبغي صيانتها.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 110, "subject": "fiqh", "course_number": 15, "chapter_index": 4, "title": "ضوابط سقوط الشروط: الذكر والقدرة", "content": "💡 التفسير التربوي: الإسلام دين واقعي يراعي أحوال العباد؛ فالعجز والنسيان عذر شرعي، لكنه يفرق بين ما هو متعلق بحرمة العبادة (كالطهارة من الحدث) وما هو متعلق بآداب الهيئة.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 111, "subject": "fiqh", "course_number": 15, "chapter_index": 5, "title": "النقاء من دم الحيض والنفاس: طهارة المرأة للصلاة", "content": "💡 التفسير التربوي: التزام المرأة بالأحكام الشرعية المتعلقة بالطهارة هو جزء من عبوديتها لله، وفهم هذه الضوابط يرفع عنها الحرج ويجعلها على بصيرة بدينها.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 112, "subject": "fiqh", "course_number": 15, "chapter_index": 6, "title": "دخول الوقت: الميقات الزمني للعبادة", "content": "💡 التفسير التربوي: احترام الأوقات في الصلاة يعلم المسلم تنظيم حياته، والالتزام بالنظام، ويؤكد أن العبادة هي التي تضبط إيقاع حياة المسلم.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 113, "subject": "fiqh", "course_number": 16, "chapter_index": 1, "title": "قراءة السورة والقيام لها", "content": "💡 التفسير التربوي: يبين هذا الجزء أن الصلاة ليست مجرد حركات، بل هي نظام متكامل من الأركان والسنن. قراءة السورة بعد الفاتحة تعزز الخشوع وتزيد من تدبر القرآن في صلاتك، والقيام لها هو تأدب مع كلام الله.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 114, "subject": "fiqh", "course_number": 16, "chapter_index": 2, "title": "أحكام الجهر والسر في الصلاة", "content": "💡 التفسير التربوي: الجهر والسر في الصلاة يربطان المصلي ببيئته (الجماعة) أو بصلته الخاصة مع الله. تعلم الضوابط الدقيقة، مثل تحريك اللسان، يصحح العبادة ويخرجها من حيز التمني إلى حيز العمل الشرعي.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 115, "subject": "fiqh", "course_number": 16, "chapter_index": 3, "title": "سنن التكبير والجلوس للتشهد", "content": "💡 التفسير التربوي: التكبيرات الانتقالية وسيلة لربط جسد المصلي بحركاته، وهي تذكر بقدسية الانتقال بين أركان الصلاة. التفرقة بين سنن الجلوس وأركان السلام تظهر عمق الفقه في التفريق بين ما هو كمالي وما هو أساسي في الصلاة.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 116, "subject": "fiqh", "course_number": 16, "chapter_index": 4, "title": "حكم التسميع وفضل السنن المؤكدة", "content": "💡 التفسير التربوي: التسميع يحقق مبدأ الترتيب الوظيفي في صلاة الجماعة، حيث يوزع المهام بين الإمام والمأموم؛ فالإمام يفتح بالذكر والمأموم يجيب بالحمد، وهو تجسيد لروح التعاون في العبادة.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 117, "subject": "fiqh", "course_number": 16, "chapter_index": 5, "title": "سنن الصلاة الخفيفة وسجودها", "content": "💡 التفسير التربوي: السنن الخفيفة كـ \"السترة\" أو \"زيادة الطمأنينة\" ليست كماليات فقط، بل هي حماية للعبادة من التشويش أو الاستعجال، وهي تدرب المسلم على الاهتمام بالتفاصيل التي ترفع من جودة صلاته.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 118, "subject": "fiqh", "course_number": 16, "chapter_index": 6, "title": "صيغ التشهد والصلاة على النبي", "content": "💡 التفسير التربوي: تنوع صيغ التشهد يعكس سعة الإسلام ورحابته. استذكار هذه الصيغ والحرص عليها يربط قلب المصلي بالنبي ﷺ، ويجعل خاتمة الصلاة مليئة بالثناء والصلاة على أشرف الخلق.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 119, "subject": "fiqh", "course_number": 17, "chapter_index": 1, "title": "المندوبات القولية الأولى في الصلاة وأحكام الرداء", "content": "يتناول هذا المحور مستهل الكلام على مندوبات الصلاة عند المالكية، مثل التيامن مع السلام، والتأمين والتحميد، وقنوت الصبح، بالإضافة إلى استحباب لبس الرداء الذي يستر عاتق وصدر المصلي.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 120, "subject": "fiqh", "course_number": 17, "chapter_index": 2, "title": "مندوبات الهيئات والحركات في الصلاة والتشهد والسجود", "content": "يشرح هذا المحور الهيئات المسنونة والمندوبة في الصلاة؛ كالتسبيح في الركوع والسجود، وحكم سدل اليدين ومقارنة التكبير للشروع، وعقد الأصابع والإشارة بالسبابة في التشهد، بالإضافة إلى تفصيل صفة السجود والجلوس والرفع.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 121, "subject": "fiqh", "course_number": 17, "chapter_index": 3, "title": "طول وقصر القراءة في الصلوات وهيئة النزول والرفع من السجود", "content": "يوضح هذا المحور تباين طول وقصر قراءة السور في الصلوات الخمس والتشهد الأوسط، بالإضافة إلى بيان الهيئة المندوبة في الهوي للسجود بتقديم اليدين أولاً، وفي الرفع بتقديم الركبتين.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 122, "subject": "fiqh", "course_number": 18, "chapter_index": 1, "title": "مندوبات الصلاة المتعلقة بالتيامن والتأمين والتحميد والقنوت والرداء", "content": "تناول الشيخ في هذا المحور جملة من أوائل مندوبات الصلاة كأهمية التيامن الخفيف عند السلام، وأحكام التأمين والتحميد للمصلي إماماً ومأموماً ومنفرداً، بالإضافة إلى حكم القنوت في صلاة الفجر وندب ستر عاتق الرجل بالرداء.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 123, "subject": "fiqh", "course_number": 18, "chapter_index": 2, "title": "مندوبات الصلاة في الهيئات البدنية والتكبير والتسبيح ومسألة السدل", "content": "شرح الشيخ هنا المندوبات الخاصة بالتسبيح في الركوع والسجود، ومقارنة التكبير للانتقال بالفعل، وصفة عقد الأصابع وتحريك السبابة في التشهد، بالإضافة لصفة السجود ومناقشة مسألة سدل اليدين في المذهب المالكي.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 124, "subject": "fiqh", "course_number": 18, "chapter_index": 3, "title": "مندوبات الصلاة في صفة الجلوس وهيئة الركوع وتفصيل القراءة والهوي للسجود", "content": "فصّل الشيخ في هذا المحور صفة الجلوس المسنونة بين الافتراش والتورك، واستواء الظهر مع تمكين الركبتين في الركوع، وقراءة المأموم في الصلاة السرية، ومقادير طول السور في الصلوات الخمس، وكيفية الهوي للسجود والرفع منه.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 125, "subject": "fiqh", "course_number": 19, "chapter_index": 1, "title": "حكم البسملة والتعوذ والسجود على الثياب وقراءة القرآن في الركوع والسجود", "content": "شرح الشيخ مجموعة من مكروهات الصلاة كالأتية بالبسملة والتعوذ في الفريضة، والسجود على كور العمامة وأطراف الثياب، وحمل شيء في الفم أو الكم، وقراءة القرآن في الركوع والسجود.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 126, "subject": "fiqh", "course_number": 19, "chapter_index": 2, "title": "أهمية الخشوع في الصلاة وطرق تحصيله والتهيؤ له", "content": "تناول الشيخ محور الخشوع مبيناً أنه روح الصلاة، وفصّل في الأسباب المعينة على تحصيله قلبيّاً وعمليّاً قبل الدخول في الصلاة وأثنائها بترك المعاصي والتبكير للمسجد واستحضار عظمة الله.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 127, "subject": "fiqh", "course_number": 19, "chapter_index": 3, "title": "مكروهات الصلاة المتعلقة بالحركات والهيئات الظاهرة", "content": "استكمل الشيخ شرح بقية المكروهات الواردة في النظم والتي تتعلق بالهيئات الظاهرة مثل العبث بالثياب، والالتفات، والدعاء أثناء القراءة في الفرض، وتشبيك الأصابع وفرقعتها، والتخصر وتغميض العينين.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 128, "subject": "fiqh", "course_number": 20, "chapter_index": 1, "title": "تقسيم الصلوات وفرضية الصلوات الخمس", "content": "شرح الشيخ تقسيم الصلوات إلى فرض ونفل، وتفصيل الفروض إلى فرض عين وفرض كفاية، مع بيان الأدلة على أن الصلوات المفروضة عيناً هي خمس صلوات.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 129, "subject": "fiqh", "course_number": 20, "chapter_index": 2, "title": "أحكام الجنائز: صلاة الجنازة وفرائضها وتجهيز الميت", "content": "بيّن الشيخ أحكام صلاة الجنازة وفرائضها الأربعة مع مناقشة حكم قراءة الفاتحة فيها، ثم فصّل الأحكام والسنن المتعلقة بتغسيل الميت وتكفينه ودفنه.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 130, "subject": "fiqh", "course_number": 20, "chapter_index": 3, "title": "الصلوات المسنونة: صلاة الوتر وصلاة الكسوف", "content": "شرح الشيخ صلاة الوتر مبيناً فضلها ووقتها الاختياري والضروري، ثم فصّل في صلاة الكسوف من حيث صفتها وهيئتها وحكم الجهر والإسرار بالقراءة فيها.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 131, "subject": "fiqh", "course_number": 21, "chapter_index": 1, "title": "صلاة العيدين ومكانهما وصفتها ومواقيتها", "content": "تناول الشيخ مشروعية صلاة العيدين (الفطر والأضحى) وصفتها كركعتين جهراً بعدهما خطبة، وبيّن عدد التكبيرات الزائدة في كل ركعة ووقت أدائها.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 132, "subject": "fiqh", "course_number": 21, "chapter_index": 2, "title": "صلاة الاستسقاء وأحكامها وصفتها", "content": "شرح الشيخ مشروعية صلاة الاستسقاء عند حبس القطر، مبيناً كيف تُصلى جماعة في المصلى، والفوارق بينها وبين صلاة العيد في التكبير وهيئة الخطبة والتضرع.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 133, "subject": "fiqh", "course_number": 21, "chapter_index": 3, "title": "رغيبة الفجر وأحكام قضاء الصلوات الفائتة", "content": "تحدث الشيخ عن رغيبة الفجر وفضلها العظيم، وميز بينها وبين فريضة الصبح، ثم تطرق إلى قضاء الصلوات المفروضة الفائتة ووجوب قضائها على الترتيب.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 134, "subject": "fiqh", "course_number": 21, "chapter_index": 4, "title": "النوافل المطلقة والمؤكدة وفضلها", "content": "أوضح الشيخ أهمية النوافل في جبر النقص الحاصل في الفرائض، ثم استعرض النوافل المؤكدة كتحية المسجد، والضحى، والتراويح، مبيناً تاريخ تشريعها.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 135, "subject": "fiqh", "course_number": 22, "chapter_index": 1, "title": "أحكام سجود السهو وحالاته في الصلاة", "content": "تناول الشيخ أحكام سجود السهو وحالاته الثلاث: النقص والزيادة واجتماعهما، مفصلاً السنن الثمانية المؤكدة، ومبينًا الفرق بين السجود القبلي والبعدي وحكم استدراكهما.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 136, "subject": "fiqh", "course_number": 22, "chapter_index": 2, "title": "مبطلات الصلاة في الفقه المالكي", "content": "استعرض الشيخ جملة من مبطلات الصلاة كالنفخ والكلام المتعمد لغير إصلاح، والحدث، والقهقهة، والأكل والشرب عمدًا، وزيادة ركن، وتذكر الصلوات الفائتة القليلة أثناء الصلاة.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 137, "subject": "fiqh", "course_number": 23, "chapter_index": 1, "title": "المجموعة الأولى من مندوبات الصلاة (التيامن والتأمين والتحميد والقنوت والرداء)", "content": "استهل الشيخ شرح مندوبات الصلاة مبيناً حكم التيامن مع السلام، وحكم تأمين المأموم والمنفرد، وصيغ التحميد، بالإضافة إلى تفصيل مسألة القنوت في صلاة الصبح، ومندوبية ستر العاتق بالرداء للرجل.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 138, "subject": "fiqh", "course_number": 23, "chapter_index": 2, "title": "تسبيح الركوع والسجود ومسائل السدل والتكبير وهيئة التشهد", "content": "تحدث الشيخ عن مندوبية التسبيح في الركوع والسجود، ثم ناقش مسألة سدل اليدين عند المالكية مقارنة بسنة القبض، وفصّل في التكبير المقارن للفعل وهيئة عقد الأصابع وتحريك السبابة في التشهد.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 139, "subject": "fiqh", "course_number": 23, "chapter_index": 3, "title": "صفة السجود والجلوس وتفاصيل قراءة السور وحركات الهوي والرفع", "content": "بين الشيخ الهيئة المسنونة للسجود ومندوبية الجلوس بالتورك والافتراش، وقراءة المأموم في السرية، وتفصيل أطوال السور في الصلوات الخمس، واختتم ببيان مندوبية تقديم اليدين عند الهوي والركبتين عند الرفع.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 140, "subject": "fiqh", "course_number": 24, "chapter_index": 1, "title": "شروط صحة الإمامة في الفقه المالكي والخلاف الفقهي فيها", "content": "تناول الشيخ بالتفصيل شروط صحة الإمامة السبعة ومنها الذكورة والتكليف والقدرة على الأركان ومعرفة أحكام الصلاة والعدالة، مبيناً الخلاف في إمامة المرأة للنساء وإمامة الصبي المميز للبالغين.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 141, "subject": "fiqh", "course_number": 24, "chapter_index": 2, "title": "شروط إمام الجمعة ومكروهات الإمامة (شروط الكمال)", "content": "أوضح الشيخ الشروط الإضافية لإمام الجمعة وهي الحرية والإقامة، ثم استعرض شروط كمال الإمامة ومكروهاتها كإمامة صاحب السلس والقروح والأشل، وإمامة البادي للحاضر، والصلاة في المسجد بلا رداء.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 142, "subject": "fiqh", "course_number": 24, "chapter_index": 3, "title": "مكروهات صلاة الجماعة وحكم إقامة جماعة ثانية بعد الإمام الراتب", "content": "شرح الشيخ مكروهات صلاة الجماعة كالصلاة بين السواري والتقدم على الإمام، ثم فصل حكم إقامة جماعة ثانية بعد الإمام الراتب في المذهب المالكي والعلة من كراهتها منعاً لتفريق وحدة المسلمين.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 143, "subject": "fiqh", "course_number": 25, "chapter_index": 1, "title": "مكروهات الإمامة وما يجوز منها", "content": "يتناول هذا المحور بيان من تكره إمامتهم كالمجهول والعبد وابن الزنا صيانةً لمنصب الإمامة الشريف، مع توضيح من تجوز إمامتهم كالأعمى والألكن والعنين وصاحب الجذام الخفيف.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 144, "subject": "fiqh", "course_number": 25, "chapter_index": 2, "title": "حكم متابعة المأموم للإمام ومستثنياتها", "content": "يشرح الشيخ وجوب متابعة المأموم لإمامه في الصلاة اقتداءً به وعدم جواز مسابقته. كما يستثني من ذلك حالة تيقن المأموم من زيادة الإمام ركعة أو سجدة، حيث يمتنع عليه متابعته فيها.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 145, "subject": "fiqh", "course_number": 25, "chapter_index": 3, "title": "أحكام المسبوق في الصلاة وقاعدتي القضاء والبناء", "content": "يفصل الشيخ في كيفية دخول المسبوق في الصلاة مع الإمام فور دخوله المسجد. كما يوضح الخلاف الفقهي في صلاته بعد سلام الإمام بناءً على قاعدتي القضاء والبناء، مبيناً المذهب المالكي المعتمد فيها.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 146, "subject": "fiqh", "course_number": 25, "chapter_index": 4, "title": "أثر بطلان صلاة الإمام وأحكام الاستخلاف", "content": "يبين الشيخ أثر بطلان صلاة الإمام على المأمومين وصحة صلاتهم عند طروء الحدث عليه. كما يفصل في أحكام استخلاف إمام آخر لإكمال الصلاة بالناس مستشهداً بحديث طعن عمر رضي الله عنه.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 147, "subject": "nahw", "course_number": 14, "chapter_index": 1, "title": "صلة الموصول (الجملة وشبه الجملة والصفة الصريحة)", "content": "يتناول هذا المحور شرح صلة الموصول وأنواعها، مبيناً أنها قد تأتي جملة اسمية أو فعلية، أو شبه جملة كالظرف والجار والمجرور، أو صفة صريحة.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 148, "subject": "nahw", "course_number": 14, "chapter_index": 2, "title": "العائد في صلة الموصول وأحكام حذفه", "content": "يوضح هذا المحور مفهوم العائد الذي يربط صلة الموصول بالاسم الموصول ووجوب مطابقته له، مع تفصيل حالات حذفه جوازاً إذا كان مرفوعاً أو منصوباً أو مجروراً.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 149, "subject": "nahw", "course_number": 14, "chapter_index": 3, "title": "المعرف بالأداة (أل) وأقسامها العهدية والجنسية", "content": "يشرح هذا الجزء المعرّف بـ 'أل' مبيناً انقسامها إلى عهدية (ذكري، ذهني، حضوري) وجنسية (لتعريف الماهية، واستغراق الأفراد أو خصائصهم)، مع التنبيه على لغة حمير.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 150, "subject": "nahw", "course_number": 15, "chapter_index": 1, "title": "تعريف الفاعل وأقسامه", "content": "عرف الشيخ الفاعل بأنه الاسم المرفوع الذي يسبقه فعل أو ما يشبهه (كاسم الفاعل والمصدر)، موضحاً أن الفاعل ينقسم إلى اسم ظاهر أو ضمير مستتر أو متصل.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 151, "subject": "nahw", "course_number": 15, "chapter_index": 2, "title": "أحكام الفاعل الأساسية", "content": "شرح الشيخ أن الفاعل عمدة لا يحذف، ولا يتقدم على فعله، وأن الأصل في الفعل أن يبقى مفرداً حتى لو كان الفاعل مثنى أو جمعاً، مع الإشارة للغة 'أكلوني البراغيث'.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 152, "subject": "nahw", "course_number": 15, "chapter_index": 3, "title": "تأنيث الفعل وتأخير الفاعل", "content": "فصّل الشيخ في وجوب تأنيث الفعل مع المؤنث الحقيقي وجوازه مع المجازي، وبيّن أحكام الترتيب بين الفاعل والمفعول به، موضحاً حالات التقديم والتأخير بينهما.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 153, "subject": "nahw", "course_number": 16, "chapter_index": 1, "title": "نائب الفاعل: تعريفه وتغيير صيغة الفعل", "content": "شرح الشيخ ماهية نائب الفاعل وكيفية تحويل الجملة الفعلية بحذف الفاعل وإقامة المفعول به مقامه، مع توضيح التغيرات النحوية التي تطرأ على الجملة.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 154, "subject": "nahw", "course_number": 16, "chapter_index": 2, "title": "قواعد بناء الفعل للمجهول (المبني للمفعول)", "content": "فصل الشيخ الأحكام الصرفية المتعلقة بتغيير صيغة الفعل (الماضي والمضارع) عند بناء الجملة للمجهول، بما في ذلك حالات الأفعال المعتلة والمبدوءة بتاء زائدة أو همزة وصل.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 155, "subject": "nahw", "course_number": 16, "chapter_index": 3, "title": "ما ينوب عن الفاعل ومسائل متفرقة", "content": "بيّن الشيخ أن النائب عن الفاعل ليس محصوراً في المفعول به، بل قد ينوب عنه الظرف أو الجار والمجرور أو المصدر، مع توضيح كيفية التعامل مع الأفعال المتعدية لمفعولين.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 156, "subject": "nahw", "course_number": 16, "chapter_index": 4, "title": "المبتدأ: تعريفه، أقسامه، ومسوغات الابتداء بالنكرة", "content": "شرح الشيخ حقيقة المبتدأ كاسم مرفوع بعامل معنوي، وأوضح الحالة التي يغني فيها فاعل اسم الفاعل (أو نائب فاعل اسم المفعول) عن الخبر، مع سرد مسوغات الابتداء بالنكرة.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 157, "subject": "nahw", "course_number": 17, "chapter_index": 1, "title": "أنواع الخبر وأقسامه", "content": "بين الشيخ تعريف الخبر كجزء متم للفائدة مع المبتدأ، وقسمه إلى مفرد (ما ليس جملة ولا شبهها) وغير مفرد (جملة اسمية أو فعلية) مع التمثيل لكل منها.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 158, "subject": "nahw", "course_number": 17, "chapter_index": 2, "title": "الخبر شبه الجملة والتعلق", "content": "شرح الشيخ أن شبه الجملة (الظرف والجار والمجرور) تقع خبراً، وهي في الحقيقة متعلقة بمحذوف وجوباً (كائن أو استقر)، ووضح القاعدة النحوية في ذلك.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 159, "subject": "nahw", "course_number": 17, "chapter_index": 3, "title": "الإخبار بظرف الزمان ومسألة تعدد الخبر", "content": "وضح الشيخ الفرق بين الإخبار عن الذوات والمعاني بظرف الزمان، مؤكداً عدم جواز الإخبار عن الذات به، ثم انتقل لبيان جواز تعدد الخبر للمبتدأ الواحد.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 160, "subject": "nahw", "course_number": 17, "chapter_index": 4, "title": "تقديم الخبر وجوباً وحذف الخبر وجوباً", "content": "فصل الشيخ حالات تقديم الخبر على المبتدأ (وجوباً وجوازاً) لأسباب بلاغية أو نحوية، كما بين المواضع الأربعة التي يجب فيها حذف الخبر وجوباً.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 161, "subject": "nahw", "course_number": 18, "chapter_index": 1, "title": "أحكام كان وأخواتها وأقسامها", "content": "شرح الشيخ عمل 'كان' وأخواتها في نسخ المبتدأ والخبر، وقسمها إلى ثلاثة أقسام: أفعال تعمل بلا شروط، وأفعال تشترط النفي أو النهي أو الدعاء، وأفعال تشترط 'ما' المصدرية الظرفية.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 162, "subject": "nahw", "course_number": 18, "chapter_index": 2, "title": "توسط وتقدم خبر كان وأخواتها وتصرفاتها", "content": "بيّن الشيخ أحكام تقديم وتأخير الخبر في جملة 'كان'، وأشار إلى أن تصاريف هذه الأفعال (المضارع، الأمر، المصدر) تعمل عمل الماضي، وأنها قد تأتي تامة (لا تحتاج لخبر).", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 163, "subject": "nahw", "course_number": 18, "chapter_index": 3, "title": "خصوصيات كان (الزيادة والحذف)", "content": "تطرق الشيخ إلى الخصائص الحصرية لـ 'كان'، مثل زيادتها في الكلام، وجواز حذفها مع اسمها وإبقاء الخبر، وشروط حذف النون من مضارعها المجزوم.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 164, "subject": "nahw", "course_number": 18, "chapter_index": 4, "title": "الحروف المشبهة بليس (ما، لا، إن)", "content": "تناول الشيخ الحروف التي تعمل عمل 'ليس' بشروط معينة عند الحجازيين، موضحاً حالات إهمالها، وخصائص 'لا' الحجازية التي تشترط تنكير اسمها وخبرها.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 165, "subject": "nahw", "course_number": 19, "chapter_index": 1, "title": "إعمال 'إن' و'لات' المشبهتين بليس", "content": "شرح الشيخ عمل 'إن' المشبهة بليس في لغة أهل العالية، وعمل 'لات' التي تختص بالدخول على لفظ 'الحين' مع حذف أحد ركنيها، والغالب حذف اسمها.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 166, "subject": "nahw", "course_number": 19, "chapter_index": 2, "title": "أقسام أفعال المقاربة وأحكام خبرها", "content": "بيّن الشيخ أقسام أفعال المقاربة (المقاربة، الرجاء، الشروع) وعملها عمل 'كان'، مع تفصيل حكم اقتران خبرها بـ'أن' المصدرية وجوباً أو جوازاً أو امتناعاً.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 167, "subject": "nahw", "course_number": 19, "chapter_index": 3, "title": "أحكام 'إن' وأخواتها ومعانيها", "content": "عرّف الشيخ بـ'إن' وأخواتها وعملها، ووضح المعاني التي تؤديها كل واحدة منها، بالإضافة إلى بيان شروط تقديم الخبر عليها.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 168, "subject": "nahw", "course_number": 19, "chapter_index": 4, "title": "مواضع كسر وفتح همزة 'إن'", "content": "فصّل الشيخ مواضع وجوب كسر همزة 'إن' (كالابتداء والقسم والقول) ومواضع فتح 'أن' (إذا أولت بمفرد كالفاعل والمفعول)، ومواضع جواز الأمرين.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 169, "subject": "nahw", "course_number": 20, "chapter_index": 1, "title": "أحكام لام الابتداء (المزحلقة)", "content": "شرح الشيخ لام الابتداء التي تدخل على خبر إنَّ، وسميت بالمزحلقة لأنها أُخرت عن موضع الصدارة كراهة اجتماع مؤكدين، ووضح المواضع الأربعة التي تدخل عليها بشرط استيفاء الشروط.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 170, "subject": "nahw", "course_number": 20, "chapter_index": 2, "title": "أثر \"ما\" الكافة على عمل \"إنَّ\" وأخواتها", "content": "أوضح الشيخ أن دخول \"ما\" الزائدة (الكافة) على إنَّ وأخواتها يبطل عملها في النصب، مما يجعل ما بعدها مبتدأً وخبراً، واستثنى من ذلك \"ليت\" لجواز الإعمال والإهمال فيها.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 171, "subject": "nahw", "course_number": 20, "chapter_index": 3, "title": "تخفيف \"إنَّ\" و\"أنَّ\" وأخواتها", "content": "بين الشيخ أحكام تخفيف الحروف الناسخة، ففي \"إنَّ\" المكسورة يكثر الإهمال ويقل الإعمال، وفي \"أنَّ\" المفتوحة يبقى الإعمال مع حذف اسم الشأن، وفي \"كأنَّ\" يجوز الإعمال والإهمال.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 172, "subject": "nahw", "course_number": 20, "chapter_index": 4, "title": "أحكام لا النافية للجنس", "content": "فصّل الشيخ في عمل \"لا\" النافية للجنس وشروطها، وبين أحكام اسم \"لا\" (المفرد والمضاف والشبيه بالمضاف)، وحالات بناء أو إعراب اسمها، وأحكام تكرارها والعطف عليها وحذف خبرها.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 173, "subject": "nahw", "course_number": 21, "chapter_index": 1, "title": "أفعال القلوب والتصيير (ظن وأخواتها)", "content": "شرح الأستاذ أحكام أفعال القلوب (كظن وحسب) وأفعال التصيير (كجعل واتخذ)، مبيناً أنها تنصب مفعولين أصلهما مبتدأ وخبر، مع تفصيل حالات شذوذ أو ندرة بعض الأفعال.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 174, "subject": "nahw", "course_number": 21, "chapter_index": 2, "title": "أحكام العامل: الإعمال والإلغاء والتعليق", "content": "فصل الشيخ الأحكام الثلاثة لأفعال ظن وأخواتها، موضحاً الفرق بين الإلغاء الذي يبطل العمل لفظاً ومحلاً بسبب التوسط أو التأخر، والتعليق الذي يمنع النصب لفظاً بسبب وجود أدوات لها الصدارة كأدوات النفي والاستفهام.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 175, "subject": "nahw", "course_number": 21, "chapter_index": 3, "title": "المفعول به: تعريفه وأحكامه وباب الاشتغال", "content": "عرّف الشيخ المفعول به كاسم يقع عليه الفعل، ثم انتقل لمسألة الاشتغال موضحاً حالات تقدم الاسم على عامل يشتغل بضميره، مؤكداً مذهب البصريين في أن الاسم المتقدم حينئذٍ يُنصب بفعل محذوف وجوباً يفسره المذكور.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 176, "subject": "sira", "course_number": 14, "chapter_index": 1, "title": "غزوة بدر الكبرى وأحداثها", "content": "تناول الشيخ تفاصيل غزوة بدر الكبرى، بدءاً من خروج النبي ﷺ لاعتراض قافلة قريش، وتغير الموازين باستنفار قريش لجيشها، وصولاً إلى استشارة النبي ﷺ للأنصار والمهاجرين وتأييدهم له، ونصر الله للمسلمين في يوم الفرقان.", "youtube_link": "https://www.youtube.com/watch?v=kXH2nzldhF8&t=34s", "timestamp_seconds": 34, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 177, "subject": "sira", "course_number": 14, "chapter_index": 2, "title": "فرض زكاة الفطر والخلاف في زكاة المال", "content": "بين الشيخ توقيت فرض زكاة الفطر في نهاية شهر رمضان من السنة الثانية للهجرة، وأشار إلى وجود خلاف علمي في توقيت فرض زكاة المال (ذات النصب)، مؤكداً على أدب الخلاف والإنصاف العلمي.", "youtube_link": "https://www.youtube.com/watch?v=kXH2nzldhF8&t=698s", "timestamp_seconds": 698, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 178, "subject": "sira", "course_number": 14, "chapter_index": 3, "title": "وفاة السيدة رقية وزواج السيدة فاطمة", "content": "تحدث الشيخ عن وفاة السيدة رقية زوجة عثمان بن عفان رضي الله عنهما قبيل عودة النبي ﷺ من بدر، وتبرئته لعثمان من التخلف عن الغزوة، ثم ذكر زواج السيدة فاطمة رضي الله عنها من علي بن أبي طالب.", "youtube_link": "https://www.youtube.com/watch?v=kXH2nzldhF8&t=1028s", "timestamp_seconds": 1028, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 179, "subject": "sira", "course_number": 14, "chapter_index": 4, "title": "إسلام العباس وقبائل يهود المدينة", "content": "شرح الشيخ قصة إسلام العباس بن عبد المطلب بعد أسره في بدر وكونه خرج مكرهاً، ثم افتتح الحديث عن القبائل اليهودية في المدينة (بنو قينقاع، النضير، قريظة) وطريقة تعامل النبي ﷺ معهم وفق الوثيقة النبوية.", "youtube_link": "https://www.youtube.com/watch?v=kXH2nzldhF8&t=1365s", "timestamp_seconds": 1365, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 180, "subject": "sira", "course_number": 15, "chapter_index": 1, "title": "غزوة بني قينقاع وأسبابها", "content": "شرح الشيخ دوافع غزوة بني قينقاع، مبيناً غدرهم ونقضهم للعهود، بدءاً من محاولاتهم التحريش بين الأوس والخزرج وصولاً إلى واقعة الصائغ والاعتداء على المرأة المسلمة.", "youtube_link": "https://www.youtube.com/watch?v=kdUugBxuUQQ&t=37s", "timestamp_seconds": 37, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 181, "subject": "sira", "course_number": 15, "chapter_index": 2, "title": "غزوة السويق وقرقرة الكدر", "content": "تناول الشيخ تفاصيل خروج أبي سفيان للانتقام بعد بدر، وكيف فر المشركون تاركين زادهم (السويق)، موضحاً الخلاف في كونها غزوة واحدة أو اثنتين بأسماء مختلفة.", "youtube_link": "https://www.youtube.com/watch?v=kdUugBxuUQQ&t=503s", "timestamp_seconds": 503, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 182, "subject": "sira", "course_number": 15, "chapter_index": 3, "title": "زواج النبي ﷺ في السنة الثالثة", "content": "استعرض الشيخ زواج النبي من السيدة حفصة بنت عمر، وقصة موقف أبي بكر الصديق الراقي مع عمر في هذا الشأن، ثم تطرق إلى زواجه من السيدة زينب بنت خزيمة الملقبة بأم المساكين.", "youtube_link": "https://www.youtube.com/watch?v=kdUugBxuUQQ&t=1018s", "timestamp_seconds": 1018, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 183, "subject": "sira", "course_number": 15, "chapter_index": 4, "title": "غزوة أحد ودروس المخالفة", "content": "شرح الشيخ مجريات غزوة أحد، بدءاً من خروج الجيش وانسحاب المنافقين، وصولاً إلى مخالفة الرماة لأمر النبي ﷺ، وما نتج عن ذلك من دروس تربوية حول حب الدنيا والآخرة.", "youtube_link": "https://www.youtube.com/watch?v=kdUugBxuUQQ&t=1503s", "timestamp_seconds": 1503, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 184, "subject": "sira", "course_number": 16, "chapter_index": 1, "title": "تتمة أحداث غزوة أحد وحمراء الأسد", "content": "💡 التفسير التربوي: غزوة حمراء الأسد كانت إثباتاً لقوة عزيمة الصحابة وإحباطاً لمعنويات قريش بعد أحد.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 185, "subject": "sira", "course_number": 16, "chapter_index": 2, "title": "تحريم الخمر وتدرج التشريع", "content": "💡 التفسير التربوي: يُظهر التدرج التشريعي رحمة الله بالعباد ومراعاته لطبائعهم، مما يؤكد على أهمية التهيئة والتربية في غرس الأحكام.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 186, "subject": "sira", "course_number": 16, "chapter_index": 3, "title": "غزوة بني النضير وإجلاؤهم", "content": "💡 التفسير التربوي: يوضح هذا الموقف حزم النبي ﷺ في التعامل مع الغدر والخيانة وحماية أمن المدينة المنورة.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 187, "subject": "sira", "course_number": 16, "chapter_index": 4, "title": "وفاة السيدة زينب بنت خزيمة رضي الله عنها (أم المساكين)", "content": "💡 التفسير التربوي: يعلمنا هذا الدرس تخليد العمل الصالح، حيث عُرفت السيدة زينب بـ 'أم المساكين' لكثرة صدقتها، ونالت شرف مرافقة النبي ﷺ في الدنيا والآخرة.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 188, "subject": "sira", "course_number": 16, "chapter_index": 5, "title": "زواج أم سلمة رضي الله عنها وقصتها", "content": "💡 التفسير التربوي: يعلمنا هذا الدرس اليقين في دعاء المصيبة والوفاء للزوج.", "youtube_link": null, "timestamp_seconds": null, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 189, "subject": "sira", "course_number": 17, "chapter_index": 1, "title": "إبطال التبني وزواج النبي ﷺ من السيدة زينب", "content": "💡 التفسير التربوي: يوضح هذا المقطع كيف وظّف الإسلام التشريع العملي لإرساء قيم اجتماعية ثابتة؛ فإلغاء التبني ليس مجرد حكم نظري، بل هو صيانة لهوية الأنساب، مع إعطاء قيمة كبرى لكفالة اليتيم دون الحاجة لتزييف النسب.", "youtube_link": "https://www.youtube.com/watch?v=vjSanXwWhtc&t=29s", "timestamp_seconds": 29, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 190, "subject": "sira", "course_number": 17, "chapter_index": 2, "title": "غزوة بدر الموعد مع قريش", "content": "💡 التفسير التربوي: يعلمنا هذا النصر المعنوي أهمية الثقة بالله والثبات أمام وعيد الأعداء، وكيف يقذف الله الرعب في قلوب الكافرين لينصر عباده المؤمنين بغير قتال.", "youtube_link": "https://www.youtube.com/watch?v=vjSanXwWhtc&t=375s", "timestamp_seconds": 375, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 191, "subject": "sira", "course_number": 17, "chapter_index": 3, "title": "غزوة الأحزاب (الخندق) وتدبير النصر", "content": "💡 التفسير التربوي: يبرز هذا الجزء أهمية التخطيط الاستراتيجي، وقبول الرأي السديد (الشورى) من أهل الخبرة مهما كانت خلفياتهم، والاعتماد على الله مع الأخذ بالأسباب الدنيوية عند اشتداد الأزمات.", "youtube_link": "https://www.youtube.com/watch?v=vjSanXwWhtc&t=458s", "timestamp_seconds": 458, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 192, "subject": "sira", "course_number": 17, "chapter_index": 4, "title": "موقف بني قريظة والغدر والخيانة", "content": "💡 التفسير التربوي: نتعلم هنا أهمية اليقظة السياسية والأمنية في وقت الحرب، وكيف يمكن لدهاء المؤمن أن يفكك تكتلات الأعداء ويحمي الأمة من الغدر الداخلي والخارجي.", "youtube_link": "https://www.youtube.com/watch?v=vjSanXwWhtc&t=869s", "timestamp_seconds": 869, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 193, "subject": "sira", "course_number": 17, "chapter_index": 5, "title": "غزوة ذات الرقاع وتخفيف الأحكام", "content": "💡 التفسير التربوي: يعلمنا هذا الدرس أن الابتلاء والمشقة في طريق الدعوة كثيراً ما يعقبهما تيسير إلهي، وأن سنن الله قائمة على تحويل المحن إلى منح تُيسر على المؤمنين حياتهم وعباداتهم.", "youtube_link": "https://www.youtube.com/watch?v=vjSanXwWhtc&t=1279s", "timestamp_seconds": 1279, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 194, "subject": "sira", "course_number": 17, "chapter_index": 6, "title": "إقامة حد الرجم ومولد الإمام الحسين", "content": "💡 التفسير التربوي: يؤكد هذا الموقف على أهمية الثبات على الحق والعدل، وعدم السماح بالتلاعب بالشرائع، مع الإشارة إلى عناية النبي ﷺ بتربية الجيل من خلال حسن اختيار الأسماء التي تحمل دلالات الرحمة والسكينة.", "youtube_link": "https://www.youtube.com/watch?v=vjSanXwWhtc&t=1612s", "timestamp_seconds": 1612, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 195, "subject": "sira", "course_number": 18, "chapter_index": 1, "title": "غزوة بني المصطلق وحادثة الإفك", "content": "شرح الشيخ تفاصيل غزوة بني المصطلق وحادثة الإفك التي تعرضت فيها السيدة عائشة للاتهام الباطل، مع بيان كيفية وقوع الحادثة وبراءة الله لها من فوق سبع سماوات.", "youtube_link": "https://www.youtube.com/watch?v=NBvsxgUpulM&t=36s", "timestamp_seconds": 36, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 196, "subject": "sira", "course_number": 18, "chapter_index": 2, "title": "غزوة دومة الجندل وزواج جويرية بنت الحارث", "content": "تناول الشيخ غزوة دومة الجندل في الجوف، ثم شرح قصة زواج النبي ﷺ من السيدة جويرية بنت الحارث، وكيف كانت بركتها سبباً في عتق الكثير من قومها.", "youtube_link": "https://www.youtube.com/watch?v=NBvsxgUpulM&t=575s", "timestamp_seconds": 575, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 197, "subject": "sira", "course_number": 18, "chapter_index": 3, "title": "غزوة بني لحيان، الاستسقاء، وغزوة ذي قرد", "content": "استعرض الشيخ أحداث السنة السادسة، بدءاً من غزوة بني لحيان، ثم معجزة استسقاء النبي ﷺ، وختمها بغزوة ذي قرد وبطولة الصحابي سلمة بن الأكوع.", "youtube_link": "https://www.youtube.com/watch?v=NBvsxgUpulM&t=849s", "timestamp_seconds": 849, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 198, "subject": "sira", "course_number": 18, "chapter_index": 4, "title": "صلح الحديبية وبيعة الرضوان", "content": "شرح الشيخ وقائع محاولة النبي ﷺ العمرة في السنة السادسة، ومنع قريش له، وما ترتب على ذلك من إرسال عثمان بن عفان ومبايعة المسلمين للنبي ﷺ تحت الشجرة.", "youtube_link": "https://www.youtube.com/watch?v=NBvsxgUpulM&t=1442s", "timestamp_seconds": 1442, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 199, "subject": "sira", "course_number": 19, "chapter_index": 1, "title": "فرضية الحج ومسألة الخلاف في توقيتها", "content": "💡 التفسير التربوي: يعلمنا هذا المبحث أهمية الأمانة العلمية في نقل الآراء الفقهية، ويوضح أن الإسلام جاء ليُطهر العبادات من بدع الجاهلية، وأن توقيتات الأحكام التشريعية مرتبطة بحكمة الله وتطور بناء الدولة الإسلامية.", "youtube_link": "https://www.youtube.com/watch?v=sbvt24ZP94s&t=33s", "timestamp_seconds": 33, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 200, "subject": "sira", "course_number": 19, "chapter_index": 2, "title": "غزوة خيبر: الضربات الاستباقية لتأمين الدولة", "content": "💡 التفسير التربوي: نستلهم من هذا الدرس حكمة القيادة النبوية في اتخاذ القرارات الاستراتيجية لحماية المجتمع، وتصفية الصفوف من المنافقين الذين يسعون للمغنم دون التزام بالعهد.", "youtube_link": "https://www.youtube.com/watch?v=sbvt24ZP94s&t=156s", "timestamp_seconds": 156, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 201, "subject": "sira", "course_number": 19, "chapter_index": 3, "title": "صلح الحديبية وأثره في نشر الدعوة", "content": "💡 التفسير التربوي: التضييق الظاهري قد يكون فيه فتح مبين، ويوضح لنا فقه الأولويات في السياسة الشرعية وكيف أن توقف القتال مكّن النبي ﷺ من تقوية أركان الدولة.", "youtube_link": "https://www.youtube.com/watch?v=sbvt24ZP94s&t=302s", "timestamp_seconds": 302, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 202, "subject": "sira", "course_number": 19, "chapter_index": 4, "title": "تحريم الحمر الأهلية ومتعة النساء", "content": "💡 التفسير التربوي: التأكيد على حجية السنة وأنها وحي من الله، وترسيخ مفهوم أن الأحكام الشرعية تهدف إلى حفظ الفطرة والكرامة الإنسانية من الأنكحة الباطلة.", "youtube_link": "https://www.youtube.com/watch?v=sbvt24ZP94s&t=514s", "timestamp_seconds": 514, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 203, "subject": "sira", "course_number": 19, "chapter_index": 5, "title": "زواج النبي ﷺ من أم حبيبة وصفية", "content": "💡 التفسير التربوي: يعكس هذا التعامل أسمى معاني الرحمة النبوية، حيث لا يمنع اختلاف المكانة الاجتماعية أو العداوة السابقة من إكرام من آمن بالله، وتثبيت قلوب المهاجرين.", "youtube_link": "https://www.youtube.com/watch?v=sbvt24ZP94s&t=850s", "timestamp_seconds": 850, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 204, "subject": "sira", "course_number": 19, "chapter_index": 6, "title": "عمرة القضاء وسنة الاضطباع والرمل", "content": "💡 التفسير التربوي: تعليم المسلم أن يظهر بيده وقوته بمظهر العزة والثقة بالنفس في مواجهة الخصوم، مع الالتزام بالسنن النبوية التي تبعث في النفس الحيوية والهيبة.", "youtube_link": "https://www.youtube.com/watch?v=sbvt24ZP94s&t=1409s", "timestamp_seconds": 1409, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 205, "subject": "sira", "course_number": 19, "chapter_index": 7, "title": "إرسال الرسل إلى ملوك الأرض", "content": "💡 التفسير التربوي: التخطيط المستقبلي والجرأة في الدعوة إلى الله، ورفض فكرة العلمانية وفصل الدين عن الحياة، وإثبات عالمية الإسلام التي تتجاوز حدود الزمان والمكان.", "youtube_link": "https://www.youtube.com/watch?v=sbvt24ZP94s&t=1768s", "timestamp_seconds": 1768, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 206, "subject": "sira", "course_number": 20, "chapter_index": 1, "title": "إهداء المقوقس لمارية القبطية وسرية مؤتة", "content": "تناول الشيخ إهداء المقوقس لمارية القبطية للنبي ﷺ، ثم انتقل للحديث عن سرية مؤتة وأسبابها ومجريات المعركة غير المتكافئة بين المسلمين والروم وحلفائهم، وكيف نجا الجيش بقيادة خالد بن الوليد.", "youtube_link": "https://www.youtube.com/watch?v=WtFKmOg2T2Y&t=57s", "timestamp_seconds": 57, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 207, "subject": "sira", "course_number": 20, "chapter_index": 2, "title": "فتح مكة وأحداثها", "content": "شرح الشيخ أسباب فتح مكة المتمثلة في نقض قريش وحلفائها للعهد بقتلهم خزاعة، وكيف تعامل النبي ﷺ مع هذا النقض، وتفاصيل تحركه بجيش كبير لفتح مكة وتطهيرها من الشرك.", "youtube_link": "https://www.youtube.com/watch?v=WtFKmOg2T2Y&t=449s", "timestamp_seconds": 449, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 208, "subject": "sira", "course_number": 20, "chapter_index": 3, "title": "غزوة حنين وحصار الطائف", "content": "تحدث الشيخ عن خروج النبي ﷺ لقتال هوازن في حنين، والدروس المستفادة من هزيمة البداية ثم النصر، وتلاها حصار الطائف والعودة للاعتمار من الجعرانة.", "youtube_link": "https://www.youtube.com/watch?v=WtFKmOg2T2Y&t=811s", "timestamp_seconds": 811, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 209, "subject": "sira", "course_number": 20, "chapter_index": 4, "title": "وقفات تربوية وأحداث ختام السنة الثامنة", "content": "استعرض الشيخ عتاب النبي ﷺ للأنصار وتطمينهم وتأكيد مكانتهم، ثم ذكر وفاة السيدة زينب ومولد إبراهيم ابن النبي ﷺ، وأخيراً قصة هبة السيدة سودة نوبتها للسيدة عائشة.", "youtube_link": "https://www.youtube.com/watch?v=WtFKmOg2T2Y&t=1088s", "timestamp_seconds": 1088, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 210, "subject": "sira", "course_number": 21, "chapter_index": 1, "title": "بناء منبر النبي وحج عتاب بن أسيد", "content": "شرح الشيخ قصة اتخاذ النبي للمنبر وحادثة حنين الجذع له، كما تناول إمارة عتاب بن أسيد على مكة في السنة الثامنة للهجرة وتوليه الحج بالناس.", "youtube_link": "https://www.youtube.com/watch?v=wTKR0lNTGiE&t=30s", "timestamp_seconds": 30, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 211, "subject": "sira", "course_number": 21, "chapter_index": 2, "title": "غزوة تبوك وهدم مسجد الضرار", "content": "تحدث الشيخ عن غزوة تبوك التي وقعت في السنة التاسعة كاختبار لصدق المسلمين، كما بين حقيقة مسجد الضرار وسبب أمر النبي ﷺ بهدمه.", "youtube_link": "https://www.youtube.com/watch?v=wTKR0lNTGiE&t=244s", "timestamp_seconds": 244, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 212, "subject": "sira", "course_number": 21, "chapter_index": 3, "title": "إرسال علي بن أبي طالب لقراءة سورة براءة", "content": "أوضح الشيخ ملابسات إرسال علي بن أبي طالب ليقرأ سورة التوبة (براءة) على الناس في الحج، ليعلن منع المشركين من الحج ومنع الطواف عراة.", "youtube_link": "https://www.youtube.com/watch?v=wTKR0lNTGiE&t=721s", "timestamp_seconds": 721, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 213, "subject": "sira", "course_number": 21, "chapter_index": 4, "title": "عام الوفود، إيلاء النبي، ووفاة إبراهيم والنجاشي", "content": "استعرض الشيخ أحداث السنة التاسعة والعاشرة، متضمناً عام الوفود، وحادثة إيلاء النبي من نسائه، وصلاة الغائب على النجاشي، وقصة وفاة إبراهيم وصلاة الكسوف.", "youtube_link": "https://www.youtube.com/watch?v=wTKR0lNTGiE&t=1048s", "timestamp_seconds": 1048, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 214, "subject": "sira", "course_number": 22, "chapter_index": 1, "title": "حجة الوداع وما تخللها من أحكام", "content": "شرح الشيخ صفة حجة النبي ﷺ (القران)، وسبب تسميتها بحجة الوداع، وبيان الخطبة النبوية التي ألقاها في يوم عرفة الذي وافق يوم جمعة.", "youtube_link": "https://www.youtube.com/watch?v=Vav4xmh5cdg&t=54s", "timestamp_seconds": 54, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 215, "subject": "sira", "course_number": 22, "chapter_index": 2, "title": "نزول آية إكمال الدين", "content": "تناول الشيخ قصة نزول قوله تعالى {الْيَوْمَ أَكْمَلْتُ لَكُمْ دِينَكُمْ} في يوم عرفة، وموقف عمر بن الخطاب رضي الله عنه حين ذكره اليهود بفضلها.", "youtube_link": "https://www.youtube.com/watch?v=Vav4xmh5cdg&t=280s", "timestamp_seconds": 280, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 216, "subject": "sira", "course_number": 22, "chapter_index": 3, "title": "وفاة النبي ﷺ ومدة مرضه", "content": "استعرض الشيخ أحداث مرض النبي ﷺ وفاته يوم الاثنين، وقصة صلاته بآخر صلاة للجماعة، وموضع دفنه في حجرة السيدة عائشة، واختلاف أهل العلم في مدة مرضه.", "youtube_link": "https://www.youtube.com/watch?v=Vav4xmh5cdg&t=524s", "timestamp_seconds": 524, "vocabulary_spoilers": null, "poetry_verses": null}, {"id": 217, "subject": "sira", "course_number": 22, "chapter_index": 4, "title": "ختام الأرجوزة الميئية", "content": "بين الشيخ دلالة تسمية المنظومة بـ (الميئية) نسبة لعدد أبياتها، وختم الدرس بالصلاة والسلام على النبي وآله وأصحابه ومن تبعهم بإحسان.", "youtube_link": "https://www.youtube.com/watch?v=Vav4xmh5cdg&t=958s", "timestamp_seconds": 958, "vocabulary_spoilers": null, "poetry_verses": null}]